{
  "name": "openskulls",
  "version": "0.2.0",
  "description": "Makes your repo readable to AI agents, then keeps it readable as the code evolves",
  "type": "module",
  "bin": {
    "openskulls": "dist/index.js"
  },
  "files": [
    "dist",
    "templates",
    "scripts",
    "install.sh",
    "install.ps1",
    "uninstall.sh"
  ],
  "scripts": {
    "gen": "bun scripts/gen-templates.ts",
    "build": "bun scripts/gen-templates.ts && rm -rf dist && tsc --project tsconfig.json && chmod +x dist/index.js",
    "compile": "bun scripts/gen-templates.ts && bun build --compile src/index.ts --outfile openskulls",
    "dev": "bun scripts/gen-templates.ts && tsc --watch",
    "typecheck": "bun scripts/gen-templates.ts && tsc --noEmit",
    "test": "bun scripts/gen-templates.ts && vitest run",
    "test:watch": "bun scripts/gen-templates.ts && vitest",
    "test:coverage": "bun scripts/gen-templates.ts && vitest run --coverage",
    "lint": "eslint 'src/**/*.ts'"
  },
  "dependencies": {
    "@clack/prompts": "^1.0.1",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "handlebars": "^4.7.8",
    "ora": "^8.1.0",
    "simple-git": "^3.25.0",
    "smol-toml": "^1.3.1",
    "zod": "3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/klaptorsk/openskulls.git"
  },
  "homepage": "https://github.com/klaptorsk/openskulls#readme",
  "bugs": {
    "url": "https://github.com/klaptorsk/openskulls/issues"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
"keywords": [
    "ai",
    "cli",
    "developer-tools",
    "claude",
    "context",
    "agentic"
  ],
  "license": "MIT"
}
